# ===================================
# Learning Platform Frontend - Configuration Template
# Copy to .env.local and customize for your environment
# ===================================

# ===================================
# API Configuration
# ===================================
# Development: Local backend
VITE_API_BASE_URL=http://localhost:8080/api

# Production: Replace with your API endpoint
# VITE_API_BASE_URL=https://api.learning-vn.com/api

# Request timeout in milliseconds
VITE_API_TIMEOUT=30000

# ===================================
# Application Configuration
# ===================================
VITE_APP_NAME=Learning-VN
VITE_APP_VERSION=1.0.0

# ===================================
# Feature Flags
# ===================================
# Enable/disable dark mode support
VITE_ENABLE_DARK_MODE=true

# Enable/disable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Enable/disable crash reporting
VITE_ENABLE_CRASH_REPORTS=false

# ===================================
# Development
# ===================================
# Enable debug logging
VITE_DEBUG=false

# ===================================
# Note: Never commit .env.local with real values!
# ===================================
# The .env.local file is in .gitignore and should contain:
# - Actual API URLs for your environment
# - Any sensitive configuration
#
# For production deployments:
# - Use environment variables from your hosting provider
# - Set VITE_API_BASE_URL to your production API URL
# - Ensure VITE_DEBUG=false in production
# ===================================

